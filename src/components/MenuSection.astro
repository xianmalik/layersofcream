---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section>
  <div class="flex items-center gap-3 mb-10">
    <span
      class="bg-tertiary-container text-on-tertiary-container px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest"
      >{title}</span
    >
    <div class="h-[2px] bg-primary-container/30 flex-grow"></div>
  </div>
  <div class="space-y-12">
    <slot />
  </div>
</section>
