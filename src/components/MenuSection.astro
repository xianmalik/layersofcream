---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section>
  <div class="mb-6">
    <span
      class="bg-tertiary-container text-on-tertiary-container px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest"
      >{title}</span
    >
  </div>
  <div class="space-y-3">
    <slot />
  </div>
</section>
