---
interface Props {
  name: string;
  price: string;
  description?: string;
}

const { name, price, description } = Astro.props;
---

<div class="group">
  <div class="flex items-end justify-between mb-1">
    <h3 class="font-headline font-bold text-xl text-primary group-hover:translate-x-1 transition-transform">
      {name}
    </h3>
    <div class="dotted-line"></div>
    <span class="font-headline font-bold text-primary">{price}</span>
  </div>
  {description && (
    <p class="text-sm text-on-surface-variant font-label italic">{description}</p>
  )}
</div>
