---
import { getCollection } from 'astro:content';
import CtaSection from '../components/CtaSection.astro';
import MenuItem from '../components/MenuItem.astro';
import MenuSection from '../components/MenuSection.astro';
import NavBar from '../components/NavBar.astro';
import Layout from '../layouts/Layout.astro';

const sections = (await getCollection('menu')).sort((a, b) => a.data.order - b.data.order);
const col1 = sections.filter((s) => s.data.column === 1);
const col2 = sections.filter((s) => s.data.column === 2);
---

<Layout title="Layers of Cream">
  <NavBar />

  <main class="pb-20 px-6 max-w-5xl mx-auto relative overflow-hidden">
    <!-- Decorative Sprinkles — SVG pill shapes in primary-fixed & tertiary-fixed -->
    <svg class="sprinkle top-28 left-0 rotate-[35deg] opacity-50" width="10" height="28" viewBox="0 0 10 28"><rect width="10" height="28" rx="5" fill="#fc8585"/></svg>
    <svg class="sprinkle top-36 left-8 rotate-[-20deg] opacity-40" width="8" height="22" viewBox="0 0 8 22"><rect width="8" height="22" rx="4" fill="#fef8c3"/></svg>
    <svg class="sprinkle top-64 -left-1 rotate-[70deg] opacity-45" width="9" height="26" viewBox="0 0 9 26"><rect width="9" height="26" rx="4.5" fill="#fc8585"/></svg>
    <svg class="sprinkle top-1/3 -right-1 rotate-[-30deg] opacity-50" width="10" height="28" viewBox="0 0 10 28"><rect width="10" height="28" rx="5" fill="#fef8c3"/></svg>
    <svg class="sprinkle top-1/2 right-6 rotate-[55deg] opacity-40" width="8" height="22" viewBox="0 0 8 22"><rect width="8" height="22" rx="4" fill="#fc8585"/></svg>
    <svg class="sprinkle bottom-48 -right-1 rotate-[-60deg] opacity-45" width="9" height="24" viewBox="0 0 9 24"><rect width="9" height="24" rx="4.5" fill="#fef8c3"/></svg>
    <svg class="sprinkle bottom-32 left-2 rotate-[15deg] opacity-40" width="8" height="20" viewBox="0 0 8 20"><rect width="8" height="20" rx="4" fill="#fc8585"/></svg>
    <svg class="sprinkle bottom-20 right-4 rotate-[-45deg] opacity-50" width="10" height="26" viewBox="0 0 10 26"><rect width="10" height="26" rx="5" fill="#fef8c3"/></svg>

    <!-- Menu Header -->
    <header class="text-center mb-20">
      <h1 class="font-headline font-extrabold text-6xl md:text-7xl text-primary mb-4 tracking-tight">
        Our Dessert Menu
      </h1>
      <p class="font-body text-lg text-on-surface-variant max-w-lg mx-auto">
        Hand-crafted patisseries, baked fresh daily with the finest ingredients and a dash of magic.
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-16 md:gap-24 relative z-10">
      <div class="space-y-16">
        {col1.map((section) => (
          <MenuSection title={section.data.title}>
            {section.data.items.map((item) => (
              <MenuItem name={item.name} price={item.price} description={item.description} />
            ))}
          </MenuSection>
        ))}
      </div>
      <div class="space-y-16">
        {col2.map((section) => (
          <MenuSection title={section.data.title}>
            {section.data.items.map((item) => (
              <MenuItem name={item.name} price={item.price} description={item.description} />
            ))}
          </MenuSection>
        ))}
      </div>
    </div>

    <CtaSection />
  </main>
</Layout>
